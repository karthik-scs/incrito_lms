# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/incrito?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Express API ──────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed CORS origins (your frontend domain(s))
CORS_ORIGIN="https://yourdomain.com"
# Public-facing base URL for the API (used in file links, webhook registration)
PUBLIC_API_URL="https://api.yourdomain.com"
# Public URL Zoom/Zoho webhooks call back to (often same as PUBLIC_API_URL)
PUBLIC_WEBHOOK_URL="https://api.yourdomain.com"

# ── Next.js (frontend) ────────────────────────────────────────────────────────
# next.config.ts proxies /api/* and /uploads/* to the Express API.
# Set this to the internal URL of the Express process (same machine → keep default localhost:4000;
# separate containers → use the container/service name, e.g. http://api:4000).
API_PROXY_TARGET="http://localhost:4000"
# NEXT_PUBLIC_API_URL: leave empty when using the built-in proxy above (recommended).
# Set only if you are NOT using the proxy and the browser must reach Express directly.
NEXT_PUBLIC_API_URL=""
# DEV only — comma-separated extra origins for HMR (tunnel/LAN IPs). Leave unset in production.
# ALLOWED_DEV_ORIGINS="your-ngrok-domain.ngrok-free.app,192.168.1.x"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET="replace-with-64-byte-hex-secret"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# ── Seed / Bootstrap ─────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="ChangeMe@2024!"
ALLOW_PROD_SEED=false

# ── OTP / Email verification ──────────────────────────────────────────────────
# Do NOT set OTP_STATIC_CODE in production — leave unset so random codes are generated
# OTP_STATIC_CODE=123456   ← DEV ONLY
EMAIL_VERIFICATION_TTL_SECONDS=600
PASSWORD_RESET_TTL_SECONDS=600

# ── AWS S3 (file storage) ─────────────────────────────────────────────────────
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="incrito-lms-uploads"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
S3_SIGNED_URL_TTL_SECONDS=600

# ── Zoho Meeting ──────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
# Region-specific — must match where your Zoho org lives
ZOHO_ACCOUNTS_DOMAIN="https://accounts.zoho.in"
ZOHO_API_DOMAIN="https://meeting.zoho.in"
